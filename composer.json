{
    "name": "sendboo/sendboo-php",
    "description": "Framework-agnostic PHP client for the Sendboo API: track events and sync subscribers from any website.",
    "type": "library",
    "license": "MIT",
    "keywords": ["sendboo", "email", "marketing", "events", "subscribers"],
    "require": {
        "php": "^8.1",
        "guzzlehttp/guzzle": "^7.5"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Sendboo\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Sendboo\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "config": {
        "sort-packages": true
    }
}
